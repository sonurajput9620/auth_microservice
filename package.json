{
  "name": "auth_microservice",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript Node.js auth microservice with Express and Prisma",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
