PORT=4100
NODE_ENV=development
LOG_LEVEL=info
LOG_DIR=./logs

# Database
DATABASE_URL="mysql://username:password@localhost:3306/auth_microservice"

# AWS / Cognito
AWS_DEFAULT_REGION="ap-south-1"
COGNITO_USER_POOL_ID="ap-south-1_examplePoolId"
COGNITO_CLIENT_ID="exampleclientid1234567890"
COGNITO_VALIDATE_AUDIENCE="true"
COGNITO_ALLOWED_CLIENT_IDS=""
COGNITO_ISSUER=""

# Hybrid token validation
AUTH_ALLOW_LEGACY_JWT="true"
LEGACY_JWT_SECRET="replace-with-a-long-random-secret"
LEGACY_JWT_ISSUER=""
LEGACY_JWT_AUDIENCE=""
AUTH_JWT_CLOCK_SKEW_SEC="30"

# Custom login OTP
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"
AUTH_OTP_TTL_MINUTES="5"
AUTH_OTP_MAX_ATTEMPTS="3"
AUTH_OTP_RESEND_COOLDOWN_SECONDS="30"

# Email delivery
# Option A: direct SMTP
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="mailer@your-domain.com"
SMTP_PASS="replace-with-your-smtp-password"
SMTP_FROM_EMAIL="mailer@your-domain.com"
SMTP_FROM_NAME="Auth Service"

# Option B: Gmail credentials from AWS SSM / Secrets Manager / env
USE_SSM_FOR_GMAIL="false"
GMAIL_SSM_BASE_PATH="/purebi/gmail"
GMAIL_SECRET_NAME=""
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Auth / SMS toggles
SMS_MOCK_MODE="true"
DISABLE_AUTH="false"
