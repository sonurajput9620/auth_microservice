PORT=4000
DATABASE_URL="mysql://root:password@localhost:3306/auth_microservice"
AWS_DEFAULT_REGION="ap-south-1"
COGNITO_REGION=""
COGNITO_CLIENT_ID=""
COGNITO_USER_POOL_ID=""
COGNITO_JWT_AUDIENCE=""
COGNITO_ALLOWED_TOKEN_USE="access,id"
AUTH_SYNC_EMAIL_FROM_COGNITO="true"
AUTH_MS_ISSUER="https://auth-ms.local"
AUTH_MS_AUDIENCE="purebi-legacy-api"
AUTH_MS_JWT_EXPIRES_IN_SEC="3600"
AUTH_MS_JWT_ACTIVE_KID="authms-rs-2026-04"
AUTH_MS_JWT_KEYS_JSON="[{\"kid\":\"authms-rs-2026-04\",\"alg\":\"RS256\",\"privateKeyPem\":\"-----BEGIN PRIVATE KEY-----\\n<pkcs8-private-key>\\n-----END PRIVATE KEY-----\",\"publicJwk\":{\"kty\":\"RSA\",\"n\":\"<base64url-n>\",\"e\":\"AQAB\"},\"enabled\":true}]"

# SMS Configuration
# Set to "true" to mock SMS (logs code to console) - useful for development without AWS SNS permissions
# Set to "false" to send real SMS via AWS SNS (requires SNS:Publish permissions)
SMS_MOCK_MODE="true"
