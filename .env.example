PORT=4000
DATABASE_URL="mysql://root:password@localhost:3306/auth_microservice"
AWS_DEFAULT_REGION="ap-south-1"
COGNITO_CLIENT_ID=""
COGNITO_USER_POOL_ID=""
COGNITO_VALIDATE_AUDIENCE="true"
COGNITO_ALLOWED_CLIENT_IDS=""

# Hybrid token validation:
# true  -> accept legacy JWT (HS256) along with Cognito JWT
# false -> disable legacy JWT and accept only Cognito JWT
AUTH_ALLOW_LEGACY_JWT="true"
LEGACY_JWT_SECRET=""
LEGACY_JWT_ISSUER=""
LEGACY_JWT_AUDIENCE=""
AUTH_JWT_CLOCK_SKEW_SEC="30"

# SMS Configuration
# Set to "true" to mock SMS (logs code to console) - useful for development without AWS SNS permissions
# Set to "false" to send real SMS via AWS SNS (requires SNS:Publish permissions)
SMS_MOCK_MODE="true"
