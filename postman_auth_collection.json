{
  "info": {
    "name": "Auth Microservice - Custom Email OTP Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Custom backend APIs for Cognito signup, email verification, admin approval, custom login email OTP, resend OTP, and Cognito forgot password."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4100" },
    { "key": "apiVersion", "value": "v1" },
    { "key": "username", "value": "jdoe01" },
    { "key": "password", "value": "StrongPass#123" },
    { "key": "newPassword", "value": "NewStrongPass#123" },
    { "key": "confirmationCode", "value": "123456" },
    { "key": "challengeCode", "value": "654321" },
    { "key": "registrationId", "value": "12" },
    { "key": "session", "value": "<login-session-id>" },
    { "key": "challengeName", "value": "CUSTOM_EMAIL_OTP" },
    { "key": "authToken", "value": "<bearer-token-for-protected-routes>" },
    { "key": "accessToken", "value": "" },
    { "key": "idToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "1. Username Availability",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/username/availability"
      }
    },
    {
      "name": "2. Sign Up",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+919999999999\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/signup"
      }
    },
    {
      "name": "3. Confirm Sign Up",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"confirmation_code\": \"{{confirmationCode}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/signup/confirm"
      }
    },
    {
      "name": "4. List Registrations",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/registrations"
      }
    },
    {
      "name": "5. Review Registration - APPROVE",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"APPROVE\",\n  \"role_id\": 2,\n  \"site_id\": 10,\n  \"corporation_id\": 1001,\n  \"approved_by\": 1,\n  \"review_note\": \"Approved by admin\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/registrations/{{registrationId}}/review"
      }
    },
    {
      "name": "6. Review Registration - REJECT",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"REJECT\",\n  \"approved_by\": 1,\n  \"review_note\": \"Missing required business details\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/registrations/{{registrationId}}/review"
      }
    },
    {
      "name": "7. Login Initiate",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.data) {",
              "  if (body.data.session) pm.collectionVariables.set('session', body.data.session);",
              "  if (body.data.challenge_name) pm.collectionVariables.set('challengeName', body.data.challenge_name);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/login/initiate"
      }
    },
    {
      "name": "8. Login Respond (Custom Email OTP)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body && body.data && body.data.tokens) {",
              "  const tokens = body.data.tokens;",
              "  if (tokens.access_token) {",
              "    pm.collectionVariables.set('accessToken', tokens.access_token);",
              "    pm.collectionVariables.set('authToken', tokens.access_token);",
              "  }",
              "  if (tokens.id_token) pm.collectionVariables.set('idToken', tokens.id_token);",
              "  if (tokens.refresh_token) pm.collectionVariables.set('refreshToken', tokens.refresh_token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"session\": \"{{session}}\",\n  \"challenge_name\": \"{{challengeName}}\",\n  \"challenge_code\": \"{{challengeCode}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/login/respond"
      }
    },
    {
      "name": "9. Resend Login OTP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"session\": \"{{session}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/login/resend"
      }
    },
    {
      "name": "10. Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/forgot-password"
      }
    },
    {
      "name": "11. Confirm Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"confirmation_code\": \"{{confirmationCode}}\",\n  \"new_password\": \"{{newPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/{{apiVersion}}/auth/forgot-password/confirm"
      }
    }
  ]
}
